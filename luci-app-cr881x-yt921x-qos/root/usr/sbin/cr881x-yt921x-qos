#!/bin/sh

set -eu

YT_CMD="/sys/kernel/debug/yt921x_cmd"
PORT_MAX=4

RATE_SCALE_NUM=1535
RATE_SCALE_DEN=1000
RATE_OFFSET=130
EIR_MIN_SAFE=300
EIR_MAX=262143

EBS_UNIT=64
EBS_MAX=16383
DEFAULT_BURST_BYTES=65536

PSCH_SHP_EBS_EIR_BASE=$((0x354000))
PSCH_SHP_CTRL_BASE=$((0x354004))
PSCH_SHP_STRIDE=8
PSCH_SHP_EN=$((1 << 4))

FILTER_MCAST_REG=$((0x180510))
FILTER_BCAST_REG=$((0x180514))
FILTER_MASK_MAX=$((0x7ff))
FILTER_MASK_DANGEROUS=$((0x7ff))

ensure_debugfs() {
	if [ ! -d /sys/kernel/debug ]; then
		return 1
	fi

	if [ ! -e "$YT_CMD" ]; then
		if ! mountpoint -q /sys/kernel/debug 2>/dev/null; then
			mount -t debugfs debugfs /sys/kernel/debug >/dev/null 2>&1 || true
		fi
	fi

	[ -w "$YT_CMD" ] && [ -r "$YT_CMD" ]
}

require_uinteger() {
	local name="$1"
	local value="$2"

	case "$value" in
	''|*[!0-9]*)
		echo "error: invalid $name '$value'" >&2
		return 1
		;;
	esac

	return 0
}

require_port() {
	local port="$1"

	require_uinteger port "$port" || return 1
	if [ "$port" -gt "$PORT_MAX" ]; then
		echo "error: port out of range (0..$PORT_MAX): $port" >&2
		return 1
	fi

	return 0
}

parse_u11_mask() {
	local name="$1"
	local value="$2"
	local parsed

	if ! printf '%s\n' "$value" | grep -Eq '^(0[xX][0-9a-fA-F]+|[0-9]+)$'; then
		echo "error: invalid $name '$value' (must be hex or decimal)" >&2
		return 1
	fi

	parsed=$((value))
	if [ "$parsed" -lt 0 ] || [ "$parsed" -gt "$FILTER_MASK_MAX" ]; then
		echo "error: $name out of range (0..0x7ff): $value" >&2
		return 1
	fi

	echo "$parsed"
}

is_force_token() {
	case "${1:-}" in
	--force|force|1|true|yes|on)
		return 0
		;;
	esac

	return 1
}

format_hex11() {
	printf '0x%03x' "$1"
}

run_cmd() {
	local cmd="$1"
	local out

	echo "$cmd" >"$YT_CMD"
	out="$(cat "$YT_CMD" 2>/dev/null || true)"
	printf '%s\n' "$out"

	case "$out" in
	err=*|*err=*)
		return 1
		;;
	esac

	return 0
}

read_reg_u32() {
	local reg="$1"
	local out
	local val_hex

	out="$(run_cmd "reg read $reg")" || return 1
	val_hex="$(printf '%s\n' "$out" | grep -Eo '0x[0-9a-fA-F]+' | tail -n1 || true)"
	if [ -z "$val_hex" ]; then
		echo "error: failed to parse register read output for $reg: $out" >&2
		return 1
	fi

	echo "$((val_hex))"
}

rate_kbps_to_eir() {
	local rate_kbps="$1"
	local eir

	require_uinteger rate_kbps "$rate_kbps" || return 1
	if [ "$rate_kbps" -eq 0 ]; then
		echo "error: rate_kbps must be > 0" >&2
		return 1
	fi

	eir=$(( (rate_kbps * RATE_SCALE_NUM + (RATE_SCALE_DEN / 2)) / RATE_SCALE_DEN + RATE_OFFSET ))
	if [ "$eir" -lt "$EIR_MIN_SAFE" ]; then
		eir="$EIR_MIN_SAFE"
	fi
	if [ "$eir" -gt "$EIR_MAX" ]; then
		echo "error: requested rate too high (EIR=$eir > $EIR_MAX)" >&2
		return 1
	fi

	echo "$eir"
}

burst_bytes_to_ebs() {
	local burst_bytes="$1"
	local ebs

	require_uinteger burst_bytes "$burst_bytes" || return 1
	if [ "$burst_bytes" -eq 0 ]; then
		echo "error: burst_bytes must be > 0" >&2
		return 1
	fi

	ebs=$(( (burst_bytes + EBS_UNIT - 1) / EBS_UNIT ))
	if [ "$ebs" -gt "$EBS_MAX" ]; then
		echo "error: requested burst too high (EBS=$ebs > $EBS_MAX)" >&2
		return 1
	fi

	echo "$ebs"
}

show_status() {
	if ! ensure_debugfs; then
		echo "error: yt921x debugfs is not available (check CONFIG_NET_DSA_YT921X_DEBUGFS)"
		return 1
	fi

	run_cmd "tbf"
}

show_status_port() {
	local port="$1"

	require_port "$port" || return 1
	run_cmd "tbf $port"
}

disable_port() {
	local port="$1"
	local reg_ctrl
	local reg_ebs_eir

	if ! ensure_debugfs; then
		echo "error: yt921x debugfs is not available (check CONFIG_NET_DSA_YT921X_DEBUGFS)"
		return 1
	fi

	require_port "$port" || return 1
	reg_ebs_eir=$((PSCH_SHP_EBS_EIR_BASE + PSCH_SHP_STRIDE * port))
	reg_ctrl=$((PSCH_SHP_CTRL_BASE + PSCH_SHP_STRIDE * port))

	run_cmd "reg write $reg_ctrl 0x0" >/dev/null
	run_cmd "reg write $reg_ebs_eir 0x0" >/dev/null
	show_status_port "$port"
}

set_port() {
	local port="$1"
	local rate_kbps="$2"
	local burst_bytes="${3:-$DEFAULT_BURST_BYTES}"
	local eir
	local ebs
	local reg_ctrl
	local reg_ebs_eir
	local val_ebs_eir

	if ! ensure_debugfs; then
		echo "error: yt921x debugfs is not available (check CONFIG_NET_DSA_YT921X_DEBUGFS)"
		return 1
	fi

	require_port "$port" || return 1
	eir="$(rate_kbps_to_eir "$rate_kbps")" || return 1
	ebs="$(burst_bytes_to_ebs "$burst_bytes")" || return 1
	reg_ebs_eir=$((PSCH_SHP_EBS_EIR_BASE + PSCH_SHP_STRIDE * port))
	reg_ctrl=$((PSCH_SHP_CTRL_BASE + PSCH_SHP_STRIDE * port))
	val_ebs_eir=$(( (ebs << 18) | eir ))

	run_cmd "reg write $reg_ctrl 0x0" >/dev/null
	run_cmd "reg write $reg_ebs_eir $val_ebs_eir" >/dev/null
	run_cmd "reg write $reg_ctrl $PSCH_SHP_EN" >/dev/null

	show_status_port "$port"
}

get_flood_filter() {
	local mcast
	local bcast

	if ! ensure_debugfs; then
		echo "error: yt921x debugfs is not available (check CONFIG_NET_DSA_YT921X_DEBUGFS)"
		return 1
	fi

	mcast="$(read_reg_u32 "$FILTER_MCAST_REG")" || return 1
	bcast="$(read_reg_u32 "$FILTER_BCAST_REG")" || return 1

	printf 'mcast=%s\n' "$(format_hex11 "$((mcast & FILTER_MASK_MAX))")"
	printf 'bcast=%s\n' "$(format_hex11 "$((bcast & FILTER_MASK_MAX))")"
}

set_flood_filter() {
	local target="$1"
	local mask_raw="$2"
	local force_token="${3:-}"
	local mask

	if ! ensure_debugfs; then
		echo "error: yt921x debugfs is not available (check CONFIG_NET_DSA_YT921X_DEBUGFS)"
		return 1
	fi

	mask="$(parse_u11_mask mask "$mask_raw")" || return 1

	if [ "$mask" -eq "$FILTER_MASK_DANGEROUS" ] && ! is_force_token "$force_token"; then
		echo "error: refusing mask 0x7ff (full drop). pass --force to override." >&2
		return 1
	fi

	case "$target" in
	mcast)
		run_cmd "reg write $FILTER_MCAST_REG $mask" >/dev/null
		;;
	bcast)
		run_cmd "reg write $FILTER_BCAST_REG $mask" >/dev/null
		;;
	both)
		run_cmd "reg write $FILTER_MCAST_REG $mask" >/dev/null
		run_cmd "reg write $FILTER_BCAST_REG $mask" >/dev/null
		;;
	*)
		echo "error: invalid target '$target' (expected mcast|bcast|both)" >&2
		return 1
		;;
	esac

	get_flood_filter
}

usage() {
	cat <<'EOF'
Usage: cr881x-yt921x-qos <command>

Commands:
  status                         Dump TBF status for all ports
  status-port <port>             Dump TBF status for one port
  set-port <port> <kbps> [burst] Set shaper on one port
  disable-port <port>            Disable shaper on one port
  get-flood-filter               Show mcast/bcast egress drop masks
  set-flood-filter <target> <mask> [--force]
                                 Set mcast/bcast/both filter mask (0..0x7ff)
EOF
}

cmd="${1:-status}"
case "$cmd" in
status)
	shift || true
	show_status "$@"
	;;
status-port)
	shift || true
	show_status_port "${1:-}"
	;;
set-port)
	shift || true
	set_port "${1:-}" "${2:-}" "${3:-$DEFAULT_BURST_BYTES}"
	;;
disable-port)
	shift || true
	disable_port "${1:-}"
	;;
get-flood-filter)
	shift || true
	get_flood_filter "$@"
	;;
set-flood-filter)
	shift || true
	set_flood_filter "${1:-}" "${2:-}" "${3:-}"
	;;
help|-h|--help)
	usage
	;;
*)
	echo "error: unknown command '$cmd'" >&2
	usage >&2
	exit 2
	;;
esac
